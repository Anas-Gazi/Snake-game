<GameScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.08, 0.10, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(14)
        spacing: dp(10)
        BoxLayout:
            size_hint_y: None
            height: dp(64)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 0.09, 0.13, 0.16, 0.94
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)]
            BoxLayout:
                orientation: "vertical"
                padding: dp(14), dp(8)
                Label:
                    text: "Score"
                    color: 0.70, 0.81, 0.76, 1
                    font_size: "13sp"
                Label:
                    text: root.score_text
                    color: 0.97, 0.98, 1, 1
                    font_size: "20sp"
                    bold: True
            BoxLayout:
                orientation: "vertical"
                padding: dp(4), dp(8)
                Label:
                    text: "Time"
                    color: 0.70, 0.81, 0.76, 1
                    font_size: "13sp"
                Label:
                    text: root.time_text
                    color: 0.97, 0.98, 1, 1
                    font_size: "20sp"
                    bold: True
            Label:
                text: "\u26a1 BOOST"
                opacity: 1 if root.boosting else 0
                color: 1.0, 0.78, 0.22, 1
                font_size: "13sp"
                bold: True
                size_hint_x: None
                width: dp(76)
            Button:
                text: root.pause_button_text
                size_hint_x: None
                width: dp(100)
                background_normal: ""
                background_color: 0.15, 0.34, 0.39, 1
                color: 1, 1, 1, 1
                on_release: root.toggle_pause()
        RelativeLayout:
            GameBoard:
                id: game_board
                pos: self.pos
                size: self.size
            # Pause overlay
            BoxLayout:
                orientation: "vertical"
                opacity: 1 if root.paused else 0
                disabled: not root.paused
                padding: dp(32)
                spacing: dp(14)
                canvas.before:
                    Color:
                        rgba: 0.02, 0.04, 0.05, 0.72 if root.paused else 0
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Widget:
                Label:
                    text: "Paused"
                    color: 0.97, 0.98, 1, 1
                    font_size: "34sp"
                    bold: True
                    size_hint_y: None
                    height: dp(52)
                Button:
                    text: "Resume"
                    size_hint_y: None
                    height: dp(54)
                    background_normal: ""
                    background_color: 0.17, 0.72, 0.53, 1
                    on_release: root.resume_game()
                Button:
                    text: "Restart"
                    size_hint_y: None
                    height: dp(54)
                    background_normal: ""
                    background_color: 0.94, 0.45, 0.22, 1
                    on_release: root.restart_game()
                Button:
                    text: "Menu"
                    size_hint_y: None
                    height: dp(54)
                    background_normal: ""
                    background_color: 0.15, 0.34, 0.39, 1
                    on_release: root.back_to_menu()
                Label:
                    text: "Arrows / WASD  \u2022  Space or Shift = Boost  \u2022  P = Pause"
                    color: 0.55, 0.65, 0.60, 1
                    font_size: "12sp"
                    size_hint_y: None
                    height: dp(22)
                Widget: